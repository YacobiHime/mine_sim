# .env.example - 環境変数テンプレート

# Minecraftサーバー設定
# 統合モード（サーバーPCで完結）の場合は localhost を設定
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.20.1

# LLMサーバー設定（Ollamaは別PC）
OLLAMA_URL=http://192.168.15.150:11434/v1
OLLAMA_MODEL=gemma4:e4b

# サーバーレスモード（開発・テスト用）
# SERVERLESS=trueを設定するとMinecraftサーバーに接続しません
# SERVERLESS=true
